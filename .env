# Project paths
DATA_DIR=.
TRAIN_FILE=train.csv
TEST_FILE=test.csv
SUBMISSION_FILE=submission.csv

# Model settings
N_FOLDS=5
RANDOM_STATE=42
N_ESTIMATORS=3000
EARLY_STOPPING_ROUNDS=100

# LightGBM hyperparameters
LGB_NUM_LEAVES=255
LGB_LEARNING_RATE=0.05
LGB_FEATURE_FRACTION=0.8
LGB_BAGGING_FRACTION=0.8
LGB_BAGGING_FREQ=5
LGB_MIN_CHILD_SAMPLES=20
LGB_REG_ALPHA=0.1
LGB_REG_LAMBDA=0.1

# XGBoost hyperparameters
XGB_MAX_DEPTH=6
XGB_LEARNING_RATE=0.05
XGB_SUBSAMPLE=0.8
XGB_COLSAMPLE_BYTREE=0.8
XGB_MIN_CHILD_WEIGHT=10
XGB_REG_ALPHA=0.1
XGB_REG_LAMBDA=1.0

# Geospatial reference point (Raffles Place / CBD)
CBD_LATITUDE=1.2830
CBD_LONGITUDE=103.8513
